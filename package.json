{
  "name": "qris-masjid",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:local": "bun run db:migrate:local && bun run dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint -c .oxlintrc.json src",
    "lint:fix": "oxlint -c .oxlintrc.json --fix src",
    "format": "oxfmt -c .oxfmtrc.json --write .",
    "format:check": "oxfmt -c .oxfmtrc.json --check .",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "ingest:nominatim": "bun scripts/ingest-nominatim-bootstrap.ts",
    "export:nominatim-db": "bun scripts/export-nominatim-db.ts",
    "run:wave2": "bun scripts/run-wave-2-data-pipeline.ts",
    "run:wave2:db": "bun scripts/run-wave-2-from-nominatim-db.ts",
    "build:d1-sync": "bun scripts/build-masjid-d1-sync.ts",
    "build:pmtiles": "bun scripts/build-masjid-pmtiles.ts",
    "build:cluster-pmtiles": "bun scripts/build-masjid-cluster-pmtiles.ts",
    "db:migrate:local": "wrangler d1 execute qris-masjid --local --file=./drizzle/0000_init.sql",
    "db:generate": "drizzle-kit generate",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.13.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "fast-png": "^8.0.0",
    "jpeg-js": "^0.4.4",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.545.0",
    "maplibre-gl": "^5.19.0",
    "pmtiles": "^4.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@cloudflare/workers-types": "^4.20260301.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "agentation": "^2.2.1",
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^27.0.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "wrangler": "^4.70.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
